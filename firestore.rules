// ─── firestore.rules ──────────────────────────────────────────────
// Add these rules to Firebase Console → Firestore → Rules
// These allow authenticated users to read/write bridge data
// for their own projects.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Existing collections ──────────────────────────────────
    match /projects/{projectId} {
      allow read, write: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null;
    }

    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    match /reportTemplates/{templateId} {
      allow read, write: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null;
    }

    match /documentPackages/{packageId} {
      allow read, write: if request.auth != null;
    }

    match /revisions/{revisionId} {
      allow read, write: if request.auth != null;
    }

    match /exports/{exportId} {
      allow read, write: if request.auth != null;
    }

    // ── Phase 5: Ecosystem Bridge ─────────────────────────────
    // Any authenticated CivilOS app can write bridge data.
    // The document ID format: {projectId}_{sourceApp}
    match /civilos_bridge/{bridgeDocId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
